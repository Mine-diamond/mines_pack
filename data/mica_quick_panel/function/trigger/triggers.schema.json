{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "triggers.schema.json",
  "title": "Mica Quick Panel Trigger 配置",
  "description": "mica_quick_panel trigger 配置文件的 JSON Schema，提供自动补全和校验。",
  "type": "object",
  "properties": {
    "modules": {
      "type": "array",
      "description": "trigger 子模块列表",
      "items": {
        "type": "object",
        "properties": {
          "dir": {
            "type": "string",
            "description": "子模块目录名（位于 trigger/ 下）",
            "enum": ["dialog", "game_rule", "simple_feature", "time_setting", "highlight", "kill_all_mob", "interaction_setting"]
          },
          "triggers": {
            "type": "array",
            "description": "该模块下的 trigger 定义列表",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^mqp\\.",
                  "description": "计分板名称，以 mqp. 开头",
                  "examples": ["mqp.dialog.game_rule", "mqp.game_rule.change"]
                },
                "display": {
                  "type": "string",
                  "description": "计分板显示名（displayname）",
                  "minLength": 1
                },
                "init": {
                  "type": "integer",
                  "description": "初始值。设 -1 使 trigger 成为「承载型」：玩家通过 trigger set 传值，tick 中读取执行。",
                  "default": null,
                  "examples": [-1]
                },
                "range": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\.$",
                  "description": "tick 中 execute 的分数匹配范围。默认 \"1..\"，承载型通常用 \"0..\"",
                  "default": "1..",
                  "examples": ["0..", "1.."]
                },
                "reset": {
                  "type": "integer",
                  "description": "tick 处理后的重置值。承载型通常重置为 -1（与 init 相同）",
                  "default": 0,
                  "examples": [-1, 0]
                },
                "mapping_actions": {
                  "type": "object",
                  "description": "值→函数映射。不同 score 值触发不同函数，按精确值匹配",
                  "propertyNames": {
                    "pattern": "^\\d+$",
                    "description": "映射值，必须是数字字符串"
                  },
                  "patternProperties": {
                    "^\\d+$": {
                      "type": "string",
                      "description": "函数路径，格式 命名空间:路径",
                      "pattern": "^[a-z_]+:[a-z_/]+$",
                      "examples": ["mica_quick_panel:game_rule_change/switch_advance_time"]
                    }
                  },
                  "additionalProperties": false,
                  "minProperties": 1
                },
                "actions": {
                  "type": "array",
                  "description": "通用操作函数列表，所有匹配玩家依次执行",
                  "items": {
                    "type": "string",
                    "description": "函数路径，格式 命名空间:路径",
                    "pattern": "^[a-z_]+:[a-z_/]+$",
                    "examples": ["mica_quick_panel:dialog/gamerule_dialog/open_gamerule_dialog"]
                  },
                  "minItems": 1
                }
              },
              "required": ["name", "display"],
              "anyOf": [
                { "required": ["actions"] },
                { "required": ["mapping_actions"] }
              ],
              "description": "trigger 定义。最少需提供 name + display + (actions 或 mapping_actions)"
            }
          }
        },
        "required": ["dir", "triggers"]
      }
    }
  },
  "required": ["modules"]
}
