{
    "type": "minecraft:confirmation",
    "pause": false,
    "title": "获取实体压缩之杖",
    "inputs": [
        {
            "type": "minecraft:number_range",
            "key": "range",
            "start": 1,
            "end": 80,
            "step": 1,
            "label": "检测范围",
            "initial": 8
        },
        {
            "key": "remove_entity",
            "type": "boolean",
            "label": "清除实体",
            "initial": true,
            "on_false": "0",
            "on_true": "1"
        }
    ],
    "yes": {
        "label": "获取",
        "action": {
            "type": "dynamic/run_command",
            "template": "trigger mqp.trigger.item.entity_compression_staff.get set $(range)$(remove_entity)"
        }
    },
    "no": {
        "label": {"translate": "gui.cancel"},
        "action": {
            "type": "show_dialog",
            "dialog": "mica_quick_panel:item/give_item"
        }
    }
}