{
    "type": "minecraft:multi_action",
    "title": "快捷面板",
    "external_title": {"text": "快捷面板", "color": "gold", "bold": true},
    "after_action": "none",
    "columns": 3,
    "pause": false,
    "actions": [
        {
            "label": "清理掉落物",
            "action": {
                "type": "run_command",
                "command": "/kill @e[type=item]"
            }
        },
        {
            "label": "清理非玩家实体",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.kill_all_mob set 1"
            }
        },
        {
            "label": "设置游戏规则",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.game_rule set 1"
            }
        },
        {
            "label": "快捷开关",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.simple_feature set 1"
            }
        },
        {
            "label": "修改时间",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.time_setting set 1"
            }
        },
        {
            "label": "高亮设置",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.highlight set 1"
            }
        },
        {
            "label": "方块交互距离设置",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.block_interaction_setting set 1"
            }
        },
        {
            "label": "实体交互距离设置",
            "action": {
                "type": "run_command",
                "command": "trigger mqp.dialog.entity_interaction_setting set 1"
            }
        },
        {
            "label": "带走生物",
            "action": {
                "type": "show_dialog",
                "dialog": "mica_quick_panel:take_entity/take_entity_dialog"
            }
        },
        {
            "label": "获取物品",
            "action": {
                "type": "show_dialog",
                "dialog": "mica_quick_panel:item/give_item"
            }
        },
        {
            "label": "关于",
            "action": {
                "type": "show_dialog",
                "dialog": "mica_quick_panel:about/about"
            }
        }
    ]
}