{
    "type": "multi_action",
    "title": "传送至看向的方块",
    "pause": false,
    "inputs": [
        {
            "type": "minecraft:number_range",
            "key": "range",
            "start": 1,
            "end": 300,
            "step": 1,
            "width": 300,
            "label": "检测范围",
            "initial": 50
        }
    ],
    "actions": [
        {
            "label": "传送",
            "action": {
                "type": "dynamic/run_command",
                "template": "trigger mqp.trigger.teleport_to_look_at.teleport set $(range)"
            }
        }
    ],
    "exit_action":{ 
        "label":{"translate": "gui.back"}, 
        "action": { 
            "type": "show_dialog", 
            "dialog": "mica_quick_panel:main/main_panel" 
        } 
    } 
}