{
    "type": "minecraft:multi_action",
    "title": "自定义攻击伤害",
    "columns": 1,
    "inputs": [
        {
            "key": "attack_damage",
            "type": "minecraft:text",
            "label": "攻击伤害",
            "initial": "1"
        }
    ],
    "actions": [
        {
            "label": "§b设置为输入值",
            "action": {
                "type": "dynamic/run_command",
                "template": "/function mines_quick_action:attack_damage_custom/custom_attack_damage {attack_damage:$(attack_damage)}"
            }
        },
        {
            "label": "无伤害",
            "tooltip": "不会有任何伤害，即使是持有武器时",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.custom_attack_damahe_trig set 1"
            }
        },
        {
            "label": "默认伤害(§a1§f)",
            "tooltip": "将伤害重置为默认值",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.custom_attack_damahe_trig set 2"
            }
        },
        {
            "label": "高伤害(§c10§f)",
            "tooltip": "将空手伤害修改为10，武器依然会影响伤害",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.custom_attack_damahe_trig set 3"
            }
        },
        {
            "label": "超级伤害(§410000000§f)",
            "tooltip": "将空手伤害修改为10000000，武器依然会影响伤害",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.custom_attack_damahe_trig set 4"
            }
        }
    ],
    "exit_action":{
        "label":{
            "translate": "gui.back"
        },
        "action": {
            "type": "show_dialog",
            "dialog": "mines_quick_action:quick"
        }
    }
}