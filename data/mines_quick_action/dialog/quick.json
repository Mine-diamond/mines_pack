{
    "type": "minecraft:multi_action",
    "columns": 3,
    "external_title": {"text": "快捷操作", "color": "gold", "bold": true},
    "title": "快捷操作",
    "after_action": "none",
    "pause": false,
    "actions": [
        {
            "label": "清理掉落物",
            "action": {
                "type": "run_command",
                "command": "/kill @e[type=item]"
            }
        },
        {
            "label": "清理非玩家实体",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:kill_all_mob_comfirm"
            }
        },
        {
            "label": "设置当前时间",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:time_setting"
            }
        },
        {
            "label": "设置方块交互距离",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:custom_block_interact_distance"
            }
        },
        {
            "label": "设置实体交互距离",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:custom_entity_interact_distance"
            }
        },
        {
            "label": "自定义攻击伤害",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:custom_attack_damage"
            }
        },
        {
            "label": "带走生物",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:pick_up_entity"
            }
        },
        {
            "label": "tp到目光位置",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:move_to_look_at"
            }
        },
        {
            "label": "获取看向的方块的距离",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:show_block_distant"
            }
        },
        {
            "label": "玩家无敌",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 1"
            },
            "tooltip": "启用后，你将不受伤害\n但是不防负面效果，比如黑暗和缓慢"
        },
        {
            "label": "赶路模式",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 3"
            },
            "tooltip": "启用后,你的速度更快,不用跳跃就能爬上10格的高度,同时在水中也不会减速"
        },
        {
            "label": "开启时间显示",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 5"
            }
        },
        {
            "label": "取消玩家无敌",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 2"
            }
        },
        {
            "label": "取消赶路模式",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 4"
            }
        },
        {
            "label": "关闭时间显示",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 6"
            }
        },
        {
            "label": "启用夜视",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 7"
            }
        },
        {
            "label": "提示死亡位置",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:death_operate"
            }
        },
        {
            "label": "高亮实体",
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:highlight_entity"
            }
        },
        {
            "label": "禁用夜视",
            "action": {
                "type": "run_command",
                "command": "/trigger mines.meun set 8"
            }
        },
        {
            "label": {
                "text": "常见游戏规则设置",
                "color": "yellow"
            },
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:usual_setting"
            }
        },
        {
            "label": {
                "text": "获取常用物品",
                "color": "yellow"
            },
            "action": {
                "type": "show_dialog",
                "dialog": "mines_quick_action:get_item"
            }
        },
        {
            "label": {
                "text": "数据包仓库链接",
                "color": "aqua"
            },
            "action": {
                "type": "open_url",
                "url": "https://github.com/Mine-diamond/mines_pack"
            },
            "tooltip": "https://github.com/Mine-diamond/mines_pack"
        }
    ]
}
